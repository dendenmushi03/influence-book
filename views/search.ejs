<%- include('partials/header') %>

<section class="page-section">
  <header class="section-head">
    <h1>検索</h1>
    <% if (keyword) { %>
      <p class="section-description search-keyword-note">検索キーワード: 「<%= keyword %>」</p>
    <% } else { %>
      <p class="section-description search-keyword-note">ヘッダーの検索欄からキーワードを入力すると、人物と本の検索結果を表示できます。</p>
    <% } %>
  </header>
</section>

<section class="page-section section-separator">
  <header class="section-head">
    <h2>人物の検索結果</h2>
  </header>

  <div class="grid">
    <% if (!keyword) { %>
      <p class="empty-state">キーワードが未入力のため、人物の検索結果は表示されていません。</p>
    <% } else if (peopleResults.length === 0) { %>
      <p class="empty-state">該当する人物は見つかりませんでした。</p>
    <% } %>

    <% peopleResults.forEach((person) => { %>
      <%- include('partials/person-card', { person, headingLevel: 'h3', showMeta: false, cardClassName: 'featured-gallery-card' }) %>
    <% }) %>
  </div>
</section>

<section class="page-section section-separator">
  <header class="section-head">
    <h2>本の検索結果</h2>
  </header>

  <div class="stack">
    <% if (!keyword) { %>
      <p class="empty-state">キーワードが未入力のため、本の検索結果は表示されていません。</p>
    <% } else if (bookResults.length === 0) { %>
      <p class="empty-state">該当する本は見つかりませんでした。</p>
    <% } %>

    <% bookResults.forEach((book) => { %>
      <article class="card book-card">
        <% if (book.coverUrl) { %>
          <img src="<%= book.coverUrl %>" alt="<%= book.title %> の書影" class="book-cover" />
        <% } else { %>
          <div class="book-cover book-cover-placeholder" aria-hidden="true"><span>No Cover</span></div>
        <% } %>

        <div class="book-card-content">
          <h3><%= book.title %></h3>
          <p class="book-author"><strong>著者:</strong> <%= book.author || '未設定' %></p>
          <p><%= book.description || '説明は未設定です。' %></p>
          <div class="links">
            <a class="person-link" href="/books/<%= book.slug %>">本の詳細を見る</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
