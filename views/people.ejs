<%- include('partials/header') %>

<section class="page-section decorated-section reveal-fade">
  <header class="section-head">
    <h1>人物一覧</h1>
    <p class="section-description">各人物の思想や価値観に影響を与えた本を、一覧で確認できます。</p>
  </header>

  <%- include('partials/people-filter-card', {
    filters,
    categories,
    countries,
    tags,
    actionPath: '/people',
    clearPath: '/people'
  }) %>

  <div class="grid">
    <% if (people.length === 0) { %>
      <% if (filters.q || filters.category || filters.country || filters.tag) { %>
        <p class="empty-state">条件に一致する人物が見つかりませんでした。条件を変更するか、<a href="/people">すべて表示</a>で再確認してください。</p>
      <% } else { %>
        <p class="empty-state">人物データがありません。</p>
      <% } %>
    <% } %>

    <% people.forEach((person) => { %>
      <% const displayName = person.displayNameJa || person.name; %>
      <article class="card person-card">
        <div class="person-visual-wrap">
          <% if (person.imageUrl) { %>
            <img src="<%= person.imageUrl %>" alt="<%= displayName %> の写真" class="person-visual" loading="lazy" />
          <% } else { %>
            <div class="person-visual person-visual-placeholder" aria-hidden="true">
              <span><%= displayName.slice(0, 1).toUpperCase() %></span>
            </div>
          <% } %>
        </div>
        <h2 class="person-card-title"><%= displayName %></h2>
        <p class="person-role"><%= person.occupation || '肩書き未設定' %></p>
        <p class="person-intro"><%= person.intro || '' %></p>
        <p class="person-category">カテゴリ: <%= person.category || '未設定' %></p>
        <% if (person.tags && person.tags.length > 0) { %>
          <div class="keywords">
            <% person.tags.forEach((tag) => { %>
              <span class="tag"><%= tag %></span>
            <% }) %>
          </div>
        <% } %>
        <a class="person-link" href="/people/<%= person.slug %>">詳細を見る</a>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
