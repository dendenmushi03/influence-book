<%- include('partials/header') %>

<section class="page-section decorated-section reveal-fade">
  <header class="section-head">
    <h1>人物一覧</h1>
    <p class="section-description">各人物の思想や価値観に影響を与えた本を、一覧で確認できます。</p>
  </header>

  <%- include('partials/people-filter-card', {
    filters,
    categories,
    countries,
    tags,
    actionPath: '/people',
    clearPath: '/people'
  }) %>

  <div class="grid">
    <% if (people.length === 0) { %>
      <% if (filters.q || filters.category || filters.country || filters.tag) { %>
        <p class="empty-state">条件に一致する人物が見つかりませんでした。条件を変更するか、<a href="/people">すべて表示</a>で再確認してください。</p>
      <% } else { %>
        <p class="empty-state">人物データがありません。</p>
      <% } %>
    <% } %>

    <% people.forEach((person) => { %>
      <%- include('partials/person-card', { person, headingLevel: 'h2', showMeta: true }) %>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
