<%- include('partials/header') %>
<%
  const heroCopyOptions = [
    {
      title: '憧れの人の思考を、読書体験から辿る。',
      lead: 'Influence Book は、信頼できる人物の読書履歴や影響を受けた本から、思考の背景を見つけるためのサービスです。'
    },
    {
      title: 'その人の思想は、どの一冊から始まったのか。',
      lead: '憧れの人物が影響を受けた本を辿り、価値観や意思決定の源流を静かに読み解きます。'
    },
    {
      title: '本棚を辿れば、思考の地図が見えてくる。',
      lead: 'Influence Book は、人物と書籍の関係を丁寧に整理し、学びの出発点を見つけるためのサービスです。'
    }
  ];
  const heroCopy = heroCopyOptions[0];
  const heroVisual = {
    src: 'https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&q=80',
    alt: '静かな書斎で本を読む人物のイメージ'
  };
%>

<section class="hero card reveal-fade">
  <div class="hero-layout">
    <div class="hero-content">
      <h1><%= heroCopy.title %></h1>
      <p class="lead"><%= heroCopy.lead %></p>
      <form class="hero-search" action="/search" method="GET">
        <input type="search" name="q" placeholder="例: Bill Gates / 長期思考 / Innovator" aria-label="検索キーワード" />
        <button type="submit">検索する</button>
      </form>
      <div class="hero-actions">
        <a class="button" href="/people">人物一覧を見る</a>
        <a class="button secondary" href="/books">本一覧を見る</a>
      </div>
    </div>

    <div class="hero-visual" aria-label="思考と読書を象徴するビジュアル">
      <img src="<%= heroVisual.src %>" alt="<%= heroVisual.alt %>" loading="lazy" />
      <span class="hero-visual-badge">Curated Reading Intelligence</span>
    </div>
  </div>
</section>

<section class="page-section decorated-section reveal-fade people-entry-section">
  <header class="section-head">
    <h2>人物を探す</h2>
    <p class="section-description">気になる人物をキーワード・カテゴリ・国・タグで絞り込み、そのまま人物一覧へ進めます。</p>
  </header>

  <%- include('partials/people-filter-card', {
    filters: peopleEntryFilters,
    categories: peopleEntryCategories,
    countries: peopleEntryCountries,
    tags: peopleEntryTags,
    actionPath: '/people',
    clearPath: '/people',
    showActiveFilters: false,
    cardClassName: 'people-entry-filter-card'
  }) %>
</section>

<section class="page-section section-separator decorated-section reveal-fade">
  <header class="section-head">
    <h2>注目の人物</h2>
    <p class="section-description">思考の源泉を知りたい人物を、厳選して掲載しています。</p>
  </header>

  <div class="grid">
    <% if (featuredPeople.length === 0) { %>
      <p class="empty-state">注目の人物はまだ登録されていません。</p>
    <% } %>

    <% featuredPeople.forEach((person) => { %>
      <% const displayName = person.displayNameJa || person.name; %>
      <article class="card person-card">
        <div class="person-visual-wrap">
          <% if (person.imageUrl) { %>
            <img src="<%= person.imageUrl %>" alt="<%= displayName %> の写真" class="person-visual" loading="lazy" />
          <% } else { %>
            <div class="person-visual person-visual-placeholder" aria-hidden="true">
              <span><%= displayName.slice(0, 1).toUpperCase() %></span>
            </div>
          <% } %>
        </div>
        <h3 class="person-card-title"><%= displayName %></h3>
        <p class="person-role"><%= person.occupation || '肩書き未設定' %></p>
        <p class="person-intro"><%= person.intro || '' %></p>
        <a class="person-link" href="/people/<%= person.slug %>">詳細を見る</a>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
