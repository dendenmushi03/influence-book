<%- include('partials/header') %>

<section class="hero card">
  <h1>Influence Book</h1>
  <p class="lead">憧れの人は、何を読んで今の思考になったのか。</p>
  <a class="button" href="/people">人物一覧を見る</a>
</section>

<section>
  <h2>注目の人物</h2>
  <div class="grid">
    <% if (featuredPeople.length === 0) { %>
      <p>注目の人物はまだ登録されていません。</p>
    <% } %>

    <% featuredPeople.forEach((person) => { %>
      <article class="card">
        <h3><%= person.name %></h3>
        <p><%= person.occupation || '肩書き未設定' %></p>
        <p><%= person.intro || '' %></p>
        <a href="/people/<%= person.slug %>">詳細を見る</a>
      </article>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
