<%- include('partials/header') %>
<%
  const heroCopyOptions = [
    {
      title: '憧れの人の思考を、読書体験から辿る。',
      lead: 'Influence Book は、信頼できる人物の読書履歴や影響を受けた本から、思考の背景を見つけるためのサービスです。'
    },
    {
      title: 'その人の思想は、どの一冊から始まったのか。',
      lead: '憧れの人物が影響を受けた本を辿り、価値観や意思決定の源流を静かに読み解きます。'
    },
    {
      title: '本棚を辿れば、思考の地図が見えてくる。',
      lead: 'Influence Book は、人物と書籍の関係を丁寧に整理し、学びの出発点を見つけるためのサービスです。'
    }
  ];
  const heroCopy = heroCopyOptions[0];
  const heroVisual = {
    src: 'https://images.unsplash.com/photo-1507842217343-583bb7270b66?auto=format&fit=crop&w=1200&q=80',
    alt: '静かな書斎で本を読む人物のイメージ'
  };
%>

<section class="hero hero-premium reveal-fade reveal-on-scroll" data-reveal>
  <div class="hero-backdrop" aria-hidden="true"></div>
  <div class="hero-layout hero-layout-premium">
    <div class="hero-content hero-content-premium">
      <p class="hero-eyebrow">Curated People Intelligence</p>
      <h1><%= heroCopy.title %></h1>
      <p class="lead"><%= heroCopy.lead %></p>
      <a class="button secondary" href="#people-entry">人物を探し始める</a>
    </div>

    <div class="hero-visual hero-visual-premium" aria-label="思考と読書を象徴するビジュアル">
      <img src="<%= heroVisual.src %>" alt="<%= heroVisual.alt %>" loading="lazy" />
      <span class="hero-visual-badge">Curated Reading Intelligence</span>
    </div>
  </div>
</section>

<section id="people-entry" class="page-section decorated-section reveal-fade reveal-on-scroll people-entry-section people-entry-premium" data-reveal>
  <header class="section-head people-entry-head">
    <h2>人物を探す</h2>
    <p class="section-description">気になる人物をキーワード・カテゴリ・国で絞り込み、そのまま人物一覧へ進めます。</p>
  </header>

  <%- include('partials/people-filter-card', {
    filters: peopleEntryFilters,
    categories: peopleEntryCategories,
    countries: peopleEntryCountries,
    tags: peopleEntryTags,
    actionPath: '/',
    clearPath: topSearchClearPath,
    showActiveFilters: false,
    showSortFilter: false,
    showTagFilter: false,
    searchPlaceholder: '人物名・肩書き・紹介文などで検索',
    cardClassName: 'people-entry-filter-card',
    inlineResults: {
      hasActiveFilters: topSearchHasActiveFilters,
      people: topSearchPeople,
      count: topSearchResultCount,
      limit: topSearchLimit,
      resultPath: topSearchResultPath,
      clearPath: topSearchClearPath
    }
  }) %>
</section>

<section class="page-section section-separator decorated-section reveal-fade reveal-on-scroll featured-gallery-section" data-reveal>
  <header class="section-head">
    <h2>注目の人物</h2>
    <p class="section-description">思考の源泉を知りたい人物を、厳選して掲載しています。</p>
  </header>

  <div class="grid featured-gallery-grid">
    <% if (featuredPeople.length === 0) { %>
      <p class="empty-state">注目の人物はまだ登録されていません。</p>
    <% } %>

    <% featuredPeople.forEach((person) => { %>
      <%- include('partials/person-card', { person, headingLevel: 'h3', showMeta: false, cardClassName: 'featured-gallery-card' }) %>
    <% }) %>
  </div>
</section>

<script src="/js/homepage.js" defer></script>
<%- include('partials/footer') %>
