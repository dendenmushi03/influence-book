<%- include('../partials/header') %>

<section class="card">
  <h1>下書き生成メニュー</h1>
  <p class="section-description">人物情報と本情報の生成導線を分離しました。必要な方だけ生成・保存できます。</p>

  <% if (errorMessage) { %>
    <p class="error-message"><%= errorMessage %></p>
  <% } %>

  <% if (generationNotice) { %>
    <p><%= generationNotice %></p>
  <% } %>

  <div class="card-subsection">
    <h2>対象人物</h2>
    <p><strong>名前:</strong> <%= person.name || '未設定' %></p>
    <p><strong>slug:</strong> <%= person.slug || '未設定' %></p>
    <p><strong>肩書き:</strong> <%= person.occupationJa || person.occupation || '未設定' %></p>
  </div>

  <div class="card-subsection">
    <h2>A. 人物情報を自動生成</h2>
    <ul>
      <li>coreMessage</li>
      <li>bio</li>
      <li>career</li>
      <li>intro</li>
    </ul>
    <a class="button" href="/admin/people/<%= person._id %>/generate/person">人物情報生成へ進む</a>
  </div>

  <div class="card-subsection">
    <h2>B. 本情報を自動生成</h2>
    <ul>
      <li>Book 候補</li>
      <li>Influence 候補</li>
      <li>kind / impactSummary / source 情報</li>
    </ul>
    <a class="button" href="/admin/people/<%= person._id %>/generate/books">本情報生成へ進む</a>
  </div>

  <p style="margin-top: 16px;"><a href="/admin/people">人物一覧に戻る</a></p>
</section>

<%- include('../partials/footer') %>
