<%- include('../partials/header') %>

<section class="card narrow">
  <h1>人物編集</h1>
  <% 
    const hasFormValue = (key) => formValues && Object.prototype.hasOwnProperty.call(formValues, key) && typeof formValues[key] !== 'undefined';
    const valueOf = (key, fallback = '') => hasFormValue(key) ? formValues[key] : (person && typeof person[key] !== 'undefined' ? person[key] : fallback);
    const textValue = (key) => valueOf(key, '') || '';
    const selectedCategory = valueOf('category', '');
    const selectedCountryJa = textValue('countryJa') || '未設定';
    const featuredRawValue = valueOf('featured', false);
    const featuredChecked = featuredRawValue === true || featuredRawValue === 'on' || featuredRawValue === 'true' || featuredRawValue === 1 || featuredRawValue === '1';
  %>
  <% if (errorMessage) { %>
    <p class="error-message"><%= errorMessage %></p>
  <% } %>
  <form action="/admin/people/<%= person._id %>" method="POST">
    <label>名前 *</label>
    <input name="name" required value="<%= textValue('name') %>" />

    <label>画像URL</label>
    <input name="imageUrl" value="<%= textValue('imageUrl') %>" placeholder="https://example.com/image.jpg" />

    <label>ページURL名 *</label>
    <input name="slug" required value="<%= textValue('slug') %>" placeholder="例: jeff-bezos" />

    <label>肩書き（日本語） *</label>
    <input name="occupationJa" required value="<%= textValue('occupationJa') %>" placeholder="例: アマゾン創業者" />

    <label>国名（日本語） *</label>
    <select name="countryJa" required>
      <% countryOptions.forEach((country) => { %>
        <option value="<%= country %>" <%= selectedCountryJa === country ? 'selected' : '' %>><%= country %></option>
      <% }) %>
      <% if (selectedCountryJa && !countryOptions.includes(selectedCountryJa)) { %>
        <option value="<%= selectedCountryJa %>" selected><%= selectedCountryJa %>（既存値）</option>
      <% } %>
    </select>

    <label>カテゴリ（主分類） *</label>
    <select name="category" required>
      <option value="">未設定</option>
      <% categoryOptions.forEach((category) => { %>
        <option value="<%= category %>" <%= selectedCategory === category ? 'selected' : '' %>><%= category %></option>
      <% }) %>
    </select>

    <label>紹介文（短文） *</label>
    <textarea name="intro" rows="2" required><%= textValue('intro') %></textarea>

    <label>career（経歴） *</label>
    <textarea name="career" rows="5" required placeholder="学歴、初期キャリア、転機、創業・現在の立場など"><%= textValue('career') %></textarea>

    <label>coreMessage（コアメッセージ）</label>
    <textarea name="coreMessage" rows="3" placeholder="この人物が繰り返し伝える中心的なメッセージ"><%= textValue('coreMessage') %></textarea>

    <label>
      <input type="checkbox" name="featured" <%= featuredChecked ? 'checked' : '' %> />
      トップページに表示
    </label>

    <button type="submit">更新する</button>
  </form>
</section>

<%- include('../partials/footer') %>
