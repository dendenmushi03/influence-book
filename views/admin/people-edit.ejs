<%- include('../partials/header') %>

<section class="card narrow">
  <h1>人物編集</h1>
  <form action="/admin/people/<%= person._id %>" method="POST">
    <label>名前 *</label>
    <input name="name" required value="<%= person.name %>" />

    <label>表示名（日本語・公開ページ優先表示）</label>
    <input name="displayNameJa" value="<%= person.displayNameJa || '' %>" placeholder="例: ジェフ・ベゾス（未入力なら name を表示）" />

    <label>slug *（URL用）</label>
    <input name="slug" required value="<%= person.slug %>" />

    <label>肩書き</label>
    <input name="occupation" value="<%= person.occupation || '' %>" />

    <label>カテゴリ</label>
    <input name="category" value="<%= person.category || '' %>" />

    <label>人気度（手動設定）</label>
    <input type="number" name="popularity" min="0" step="1" value="<%= person.popularity || 0 %>" />

    <label>タグ（カンマ区切り）</label>
    <input name="tags" value="<%= (person.tags || []).join(', ') %>" />

    <label>紹介文（短文）</label>
    <textarea name="intro" rows="2"><%= person.intro || '' %></textarea>

    <label>summary（思考の要約）</label>
    <textarea name="summary" rows="4" placeholder="この人物の思考の特徴を3〜5行で要約"><%= person.summary || '' %></textarea>

    <label>career（経歴）</label>
    <textarea name="career" rows="5" placeholder="学歴、初期キャリア、転機、創業・現在の立場など"><%= person.career || '' %></textarea>

    <label>bio（プロフィール補足）</label>
    <textarea name="bio" rows="4" placeholder="人物像の補足や背景情報（summary / career に入らない要素）"><%= person.bio || '' %></textarea>

    <label>画像URL</label>
    <input name="imageUrl" value="<%= person.imageUrl || '' %>" />

    <label>キーワード（カンマ区切り）</label>
    <input name="keywords" value="<%= (person.keywords || []).join(', ') %>" />

    <label>
      <input type="checkbox" name="featured" <%= person.featured ? 'checked' : '' %> />
      トップページに表示
    </label>

    <button type="submit">更新する</button>
  </form>
</section>

<%- include('../partials/footer') %>
