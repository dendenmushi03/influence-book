<%- include('../partials/header') %>

<section class="card narrow">
  <h1>人物編集</h1>
  <% const values = Object.assign({}, person, formValues || {}); %>
  <% if (errorMessage) { %>
    <p class="error-message"><%= errorMessage %></p>
  <% } %>
  <form action="/admin/people/<%= person._id %>" method="POST">
    <label>名前 *</label>
    <input name="name" required value="<%= values.name || '' %>" />

    <label>表示名（日本語・公開ページ優先表示）</label>
    <input name="displayNameJa" value="<%= values.displayNameJa || '' %>" placeholder="例: ジェフ・ベゾス（未入力なら name を表示）" />

    <label>slug *（URL用）</label>
    <input name="slug" required value="<%= values.slug || '' %>" />

    <label>肩書き</label>
    <input name="occupation" value="<%= values.occupation || '' %>" />

    <label>肩書き（日本語表示優先）</label>
    <input name="occupationJa" value="<%= values.occupationJa || '' %>" placeholder="例: アマゾン創業者" />

    <label>肩書き（英語）</label>
    <input name="occupationEn" value="<%= values.occupationEn || '' %>" placeholder="例: Founder, Amazon" />

    <label>国コード（検索用・任意）</label>
    <input name="countryCode" value="<%= values.countryCode || '' %>" placeholder="例: US / JP" />

    <label>国名（日本語）</label>
    <input name="countryJa" value="<%= values.countryJa || '' %>" placeholder="例: アメリカ" />

    <label>国名（英語）</label>
    <input name="countryEn" value="<%= values.countryEn || '' %>" placeholder="例: United States" />

    <label>カテゴリ（主分類）</label>
    <select name="category">
      <option value="">未設定</option>
      <% categoryOptions.forEach((category) => { %>
        <option value="<%= category %>" <%= values.category === category ? 'selected' : '' %>><%= category %></option>
      <% }) %>
    </select>

    <label>人気度（手動設定）</label>
    <input type="number" name="popularity" min="0" step="1" value="<%= values.popularity || 0 %>" />

    <label>タグ（カンマ区切り）</label>
    <input name="tags" value="<%= Array.isArray(values.tags) ? values.tags.join(', ') : (values.tags || '') %>" />

    <label>紹介文（短文）</label>
    <textarea name="intro" rows="2"><%= values.intro || '' %></textarea>

    <label>summary（思考の要約）</label>
    <textarea name="summary" rows="4" placeholder="この人物の思考の特徴を3〜5行で要約"><%= values.summary || '' %></textarea>

    <label>career（経歴）</label>
    <textarea name="career" rows="5" placeholder="学歴、初期キャリア、転機、創業・現在の立場など"><%= values.career || '' %></textarea>

    <label>bio（プロフィール補足）</label>
    <textarea name="bio" rows="4" placeholder="人物像の補足や背景情報（summary / career に入らない要素）"><%= values.bio || '' %></textarea>

    <label>画像URL</label>
    <input name="imageUrl" value="<%= values.imageUrl || '' %>" placeholder="https://example.com/image.jpg" />

    <label>キーワード（カンマ区切り）</label>
    <input name="keywords" value="<%= Array.isArray(values.keywords) ? values.keywords.join(', ') : (values.keywords || '') %>" />

    <label>
      <input type="checkbox" name="featured" <%= values.featured ? 'checked' : '' %> />
      トップページに表示
    </label>

    <button type="submit">更新する</button>
  </form>
</section>

<%- include('../partials/footer') %>
