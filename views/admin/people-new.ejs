<%- include('../partials/header') %>

<section class="card narrow">
  <h1>人物追加</h1>
  <% if (errorMessage) { %>
    <p class="error-message"><%= errorMessage %></p>
  <% } %>
  <form action="/admin/people" method="POST">
    <label>名前 *</label>
    <input name="name" required value="<%= formValues.name || '' %>" />

    <label>画像URL</label>
    <input name="imageUrl" value="<%= formValues.imageUrl || '' %>" placeholder="https://example.com/image.jpg" />

    <label>coreMessage（コアメッセージ）</label>
    <textarea name="coreMessage" rows="3" placeholder="この人物が繰り返し伝える中心的なメッセージ"><%= formValues.coreMessage || '' %></textarea>

    <label>ページURL名 *</label>
    <input name="slug" required value="<%= formValues.slug || '' %>" placeholder="例: jeff-bezos" />

    <label>肩書き（日本語） *</label>
    <input name="occupationJa" required value="<%= formValues.occupationJa || '' %>" placeholder="例: アマゾン創業者" />

    <label>国名（日本語） *</label>
    <select name="countryJa" required>
      <% countryOptions.forEach((country) => { %>
        <option value="<%= country %>" <%= (formValues.countryJa || '未設定') === country ? 'selected' : '' %>><%= country %></option>
      <% }) %>
      <% if (formValues.countryJa && !countryOptions.includes(formValues.countryJa)) { %>
        <option value="<%= formValues.countryJa %>" selected><%= formValues.countryJa %>（既存値）</option>
      <% } %>
    </select>

    <label>カテゴリ（主分類） *</label>
    <select name="category" required>
      <option value="">未設定</option>
      <% categoryOptions.forEach((category) => { %>
        <option value="<%= category %>" <%= formValues.category === category ? 'selected' : '' %>><%= category %></option>
      <% }) %>
    </select>

    <label>人物説明</label>
    <textarea name="bio" rows="5" placeholder="人物の背景や考え方、代表的な実績などを記入してください"><%= formValues.bio || '' %></textarea>

    <label>career（経歴） *</label>
    <textarea name="career" rows="5" required placeholder="学歴、初期キャリア、転機、創業・現在の立場など"><%= formValues.career || '' %></textarea>

    <label>人物カード表示用紹介文（短文） *</label>
    <textarea name="intro" rows="2" required><%= formValues.intro || '' %></textarea>

    <label>
      <input type="checkbox" name="featured" <%= formValues.featured === 'on' ? 'checked' : '' %> />
      トップページに表示
    </label>

    <label>
      <input type="checkbox" name="saveAsDraft" <%= formValues.saveAsDraft === 'on' ? 'checked' : '' %> />
      下書きとして高速保存（未入力は仮値で補完）
    </label>

    <button type="submit">登録する</button>
  </form>
</section>

<%- include('../partials/footer') %>
