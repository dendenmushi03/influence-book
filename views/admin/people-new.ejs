<%- include('../partials/header') %>

<section class="card narrow">
  <h1>人物追加</h1>
  <form action="/admin/people" method="POST">
    <label>名前 *</label>
    <input name="name" required />

    <label>表示名（日本語・公開ページ優先表示）</label>
    <input name="displayNameJa" placeholder="例: ジェフ・ベゾス（未入力なら name を表示）" />

    <label>slug *（URL用）</label>
    <input name="slug" required />

    <label>肩書き</label>
    <input name="occupation" />

    <label>肩書き（日本語表示優先）</label>
    <input name="occupationJa" placeholder="例: アマゾン創業者" />

    <label>肩書き（英語）</label>
    <input name="occupationEn" placeholder="例: Founder, Amazon" />

    <label>国コード（検索用・任意）</label>
    <input name="countryCode" placeholder="例: US / JP" />

    <label>国名（日本語）</label>
    <input name="countryJa" placeholder="例: アメリカ" />

    <label>国名（英語）</label>
    <input name="countryEn" placeholder="例: United States" />

    <label>カテゴリ</label>
    <input name="category" placeholder="起業家" />

    <label>人気度（手動設定）</label>
    <input type="number" name="popularity" min="0" step="1" value="0" />

    <label>タグ（カンマ区切り）</label>
    <input name="tags" placeholder="経営, 長期思考, テクノロジー" />

    <label>紹介文（短文）</label>
    <textarea name="intro" rows="2"></textarea>

    <label>summary（思考の要約）</label>
    <textarea name="summary" rows="4" placeholder="この人物の思考の特徴を3〜5行で要約"></textarea>

    <label>career（経歴）</label>
    <textarea name="career" rows="5" placeholder="学歴、初期キャリア、転機、創業・現在の立場など"></textarea>

    <label>bio（プロフィール補足）</label>
    <textarea name="bio" rows="4" placeholder="人物像の補足や背景情報（summary / career に入らない要素）"></textarea>

    <label>画像URL</label>
    <input name="imageUrl" placeholder="https://example.com/image.jpg" />

    <label>キーワード（カンマ区切り）</label>
    <input name="keywords" placeholder="経営, テクノロジー" />

    <label>
      <input type="checkbox" name="featured" />
      トップページに表示
    </label>

    <button type="submit">登録する</button>
  </form>
</section>

<%- include('../partials/footer') %>
