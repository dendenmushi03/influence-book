<%- include('../partials/header') %>

<section class="card narrow">
  <h1>本編集</h1>
  <form action="/admin/books/<%= book._id %>" method="POST">
    <label>タイトル *</label>
    <input name="title" required value="<%= book.title %>" />

    <label>slug *（URL用 / 未入力ならタイトルから生成）</label>
    <input name="slug" value="<%= book.slug || '' %>" />

    <label>著者</label>
    <input name="author" value="<%= book.author || '' %>" />

    <label>ISBN</label>
    <input name="isbn" value="<%= book.isbn || '' %>" />

    <label>書影URL</label>
    <input name="coverUrl" value="<%= book.coverUrl || '' %>" />

    <label>説明</label>
    <textarea name="description" rows="4"><%= book.description || '' %></textarea>

    <label>Amazon URL</label>
    <input name="amazonUrl" value="<%= book.amazonUrl || '' %>" />

    <label>楽天 URL</label>
    <input name="rakutenUrl" value="<%= book.rakutenUrl || '' %>" />

    <button type="submit">更新する</button>
  </form>
</section>

<%- include('../partials/footer') %>
