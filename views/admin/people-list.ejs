<%- include('../partials/header') %>

<section class="page-section">
  <h1>人物一覧（管理）</h1>
  <p class="section-description">登録済みの人物データです。</p>
</section>

<section class="stack">
  <% if (people.length === 0) { %>
    <article class="card">
      <p>人物データがありません。</p>
    </article>
  <% } %>

  <% people.forEach((person) => { %>
    <article class="card list-card">
      <div>
        <h2><%= person.name %></h2>
        <p><strong>スラッグ:</strong> <%= person.slug %></p>
        <p><strong>肩書き:</strong> <%= person.occupation || '未設定' %></p>
      </div>

      <div class="admin-link-group">
        <a class="button secondary" href="/admin/people/<%= person._id %>/edit">編集</a>
        <form action="/admin/people/<%= person._id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('この人物を削除しますか？')">
          <button type="submit" class="button danger">削除</button>
        </form>
        <a href="/people/<%= person.slug %>">公開ページを見る</a>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>
