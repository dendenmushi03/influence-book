<%- include('../partials/header') %>

<section class="page-section">
  <h1>人物一覧（管理）</h1>
  <p class="section-description">登録済みの人物データです。</p>
  <% if (saveResult) { %>
    <p><strong>下書き保存完了:</strong> 人物更新 <%= saveResult.personUpdatedFields.length %>件 / 本(新規 <%= saveResult.booksCreated %>件, 再利用 <%= saveResult.booksReused %>件) / Influence(新規 <%= saveResult.influencesCreated %>件, 再利用 <%= saveResult.influencesReused %>件)</p>
  <% } %>
</section>

<section class="stack">
  <% if (people.length === 0) { %>
    <article class="card">
      <p>人物データがありません。</p>
    </article>
  <% } %>

  <% people.forEach((person) => { %>
    <article class="card list-card">
      <div>
        <h2><%= person.name %></h2>
        <p><strong>表示名（日本語）:</strong> <%= person.displayNameJa || '未設定' %></p>
        <p><strong>スラッグ:</strong> <%= person.slug %></p>
        <p><strong>肩書き:</strong> <%= person.occupationJa || person.occupation || '未設定' %></p>
        <p><strong>カテゴリ:</strong> <%= person.category || '未設定' %></p>
        <p><strong>人気度:</strong> <%= person.popularity || 0 %></p>
      </div>
      <div class="admin-link-group">
        <a href="/people/<%= person.slug %>">公開ページを見る</a>
        <a href="/admin/people/<%= person._id %>/edit">編集する</a>
        <a href="/admin/people/<%= person._id %>/influences">関連本を管理</a>
        <a href="/admin/people/<%= person._id %>/generate">情報登録（下書き生成）</a>
        <form action="/admin/people/<%= person._id %>/delete" method="POST" onsubmit="return confirm('この人物を削除しますか？');">
          <button class="button secondary" type="submit">削除</button>
        </form>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>
