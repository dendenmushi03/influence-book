<%- include('../partials/header') %>

<section class="page-section">
  <h1>管理ダッシュボード</h1>
  <p class="section-description">新規登録と登録済みデータの確認をここから行えます。</p>
  <form action="/admin/logout" method="POST">
    <button class="button secondary" type="submit">ログアウト</button>
  </form>
</section>

<section class="admin-actions-grid">
  <article class="card">
    <h2>人物</h2>
    <div class="admin-link-group">
      <a class="button" href="/admin/people/new">新規追加</a>
      <a class="button secondary" href="/admin/people">一覧を見る</a>
    </div>
  </article>

  <article class="card">
    <h2>本</h2>
    <div class="admin-link-group">
      <a class="button" href="/admin/books/new">新規追加</a>
      <a class="button secondary" href="/admin/books">一覧を見る</a>
    </div>
  </article>

  <article class="card">
    <h2>影響関係</h2>
    <div class="admin-link-group">
      <a class="button" href="/admin/influences/new">新規追加</a>
      <a class="button secondary" href="/admin/influences/bulk">一括登録</a>
      <a class="button secondary" href="/admin/influences">人物ごとに管理</a>
    </div>
