<%- include('../partials/header') %>

<section class="page-section">
  <h1>影響関係一覧（管理）</h1>
  <p class="section-description">人物名・本タイトル・種類・表示順を確認できます。</p>
  <div class="admin-link-group" style="margin-top: 12px;">
    <a class="button" href="/admin/influences/new">単冊追加</a>
    <a class="button secondary" href="/admin/influences/bulk">一括登録</a>
  </div>
</section>

<section class="stack">
  <% if (influences.length === 0) { %>
    <article class="card">
      <p>影響関係データがありません。</p>
    </article>
  <% } %>

  <% influences.forEach((influence) => { %>
    <article class="card list-card">
      <div>
        <h2><%= influence.personId ? influence.personId.name : '人物不明' %></h2>
        <p><strong>本:</strong> <%= influence.bookId ? influence.bookId.title : '本情報なし' %></p>
        <p><strong>種類:</strong> <%= influence.kind === 'about' ? 'about（この人を知る本）' : 'influence（影響を受けた本）' %></p>
        <p><strong>featuredOrder:</strong> <%= influence.featuredOrder %></p>
      </div>
      <div>
        <p><strong>影響要約:</strong> <%= influence.impactSummary || '未設定' %></p>
        <div class="admin-link-group">
          <a href="/admin/influences/<%= influence._id %>/edit">編集する</a>
          <form action="/admin/influences/<%= influence._id %>/delete" method="POST" onsubmit="return confirm('この影響関係を削除しますか？');">
            <button class="button secondary" type="submit">削除</button>
          </form>
        </div>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>
