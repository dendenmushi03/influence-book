<%- include('../partials/header') %>

<section class="page-section">
  <h1>人物ごとの関連本管理（管理）</h1>
  <p class="section-description">人物ページごとに、表示する関連本（Influence）を管理します。</p>
  <div class="admin-link-group" style="margin-top: 12px;">
    <a class="button" href="/admin/influences/new">単冊追加（人物選択あり）</a>
    <a class="button secondary" href="/admin/influences/bulk">一括登録</a>
  </div>
</section>

<section class="stack">
  <% if (people.length === 0) { %>
    <article class="card">
      <p>人物データがありません。</p>
    </article>
  <% } %>

  <% people.forEach((person) => { %>
    <article class="card list-card">
      <div>
        <h2><%= person.name %></h2>
        <p><strong>slug:</strong> <%= person.slug %></p>
        <p><strong>関連本件数:</strong> <%= person.influenceCount || 0 %> 件</p>
      </div>
      <div class="admin-link-group">
        <a class="button" href="/admin/people/<%= person._id %>/influences">関連本を管理</a>
      </div>
    </article>
  <% }) %>
</section>

<%- include('../partials/footer') %>
