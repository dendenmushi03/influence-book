<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof pageTitle !== 'undefined' && pageTitle ? `${pageTitle} | Influence Book` : 'Influence Book' %></title>
    <meta name="description" content="憧れの人が影響を受けた本から、思考の背景を辿るサービス" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Influence Book" />
    <meta property="og:description" content="憧れの人が影響を受けた本から、思考の背景を辿るサービス" />
    <meta property="og:site_name" content="Influence Book" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content="/favicon.svg" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo">Influence Book</a>
        <nav class="site-nav" aria-label="グローバルナビゲーション">
          <a href="/people">人物一覧</a>
          <a href="/books">本一覧</a>
          <a class="admin-link" href="/admin">管理画面</a>
        </nav>
        <button class="mobile-menu-toggle" type="button" aria-expanded="false" aria-controls="mobile-menu-panel">
          MENU
        </button>
        <form class="header-search" action="/search" method="GET">
          <input type="search" name="q" placeholder="人物名・本タイトルで検索" aria-label="人物名・本タイトルで検索" />
          <button class="search-submit-button" type="submit">検索</button>
        </form>
      </div>
      <div class="mobile-menu" id="mobile-menu-panel" role="dialog" aria-modal="true" aria-label="スマホメニュー" hidden>
        <button class="mobile-menu-backdrop" type="button" aria-label="メニューを閉じる"></button>
        <div class="mobile-menu-panel" role="document">
          <div class="mobile-menu-header">
            <span class="mobile-menu-title">Menu</span>
            <button class="mobile-menu-close" type="button" aria-label="メニューを閉じる">×</button>
          </div>

          <div class="mobile-menu-section" aria-label="サイトトップ導線">
            <p class="mobile-menu-section-label">サイトTOP</p>
            <nav class="mobile-menu-nav" aria-label="モバイルナビゲーション">
              <a href="/" class="mobile-menu-link"><span>ホーム</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
            </nav>
          </div>

          <div class="mobile-menu-section" aria-label="主要導線">
            <p class="mobile-menu-section-label">ナビゲーション</p>
            <nav class="mobile-menu-nav" aria-label="主要メニュー">
              <a href="/search" class="mobile-menu-link"><span>検索する</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
              <a href="/people" class="mobile-menu-link"><span>人物一覧</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
              <a href="/books" class="mobile-menu-link"><span>本一覧</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
            </nav>
          </div>

          <div class="mobile-menu-section" aria-label="運営者導線">
            <p class="mobile-menu-section-label">運営者向け</p>
            <nav class="mobile-menu-nav" aria-label="管理メニュー">
              <a href="/admin" class="mobile-menu-link"><span>管理画面</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
            </nav>
          </div>

          <div class="mobile-menu-section" aria-label="固定ページ導線">
            <p class="mobile-menu-section-label">インフォメーション</p>
            <nav class="mobile-menu-nav" aria-label="補助メニュー">
              <a href="/affiliate-disclosure" class="mobile-menu-link"><span>アフィリエイト開示</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
              <a href="/privacy-policy" class="mobile-menu-link"><span>プライバシーポリシー</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
              <a href="/contact" class="mobile-menu-link"><span>お問い合わせ</span><span class="mobile-menu-link-arrow" aria-hidden="true">›</span></a>
            </nav>
          </div>
        </div>
      </div>
    </header>
    <main class="container">
