<%
  const resolvedActionPath = actionPath || '/people';
  const shouldShowActiveFilters = showActiveFilters !== false;
  const clearLinkPath = clearPath || resolvedActionPath;
  const hasActiveFilters = Boolean(filters.q || filters.category || filters.country || filters.tag || filters.sort === 'new');
  const toQuery = (params) =>
    Object.entries(params)
      .filter(([, value]) => value)
      .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(value)}`)
      .join('&');
%>

<article class="card filter-card <%= cardClassName || '' %>">
  <form class="people-search-form" action="<%= resolvedActionPath %>" method="GET">
    <input
      type="search"
      name="q"
      value="<%= filters.q || '' %>"
      placeholder="人物名・肩書き・紹介文・タグなどで検索"
      aria-label="人物のキーワード検索"
    />
    <input type="hidden" name="category" value="<%= filters.category || '' %>" />
    <input type="hidden" name="country" value="<%= filters.country || '' %>" />
    <input type="hidden" name="tag" value="<%= filters.tag || '' %>" />
    <input type="hidden" name="sort" value="<%= filters.sort || 'popular' %>" />
    <button type="submit">検索</button>
  </form>

  <div class="filter-group">
    <p class="filter-group-label">カテゴリ</p>
    <div class="filter-chip-list">
      <a
        class="filter-chip <%= !filters.category ? 'filter-chip-active' : '' %>"
        href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, country: filters.country, sort: filters.sort, tag: filters.tag }) %>"
      >すべて</a>
      <% categories.forEach((category) => { %>
        <a
          class="filter-chip <%= filters.category === category ? 'filter-chip-active' : '' %>"
          href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category, country: filters.country, sort: filters.sort, tag: filters.tag }) %>"
        ><%= category %></a>
      <% }) %>
    </div>
  </div>

  <div class="filter-group">
    <p class="filter-group-label">国</p>
    <div class="filter-chip-list">
      <a
        class="filter-chip <%= !filters.country ? 'filter-chip-active' : '' %>"
        href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, sort: filters.sort, tag: filters.tag }) %>"
      >すべて</a>
      <% countries.forEach((country) => { %>
        <a
          class="filter-chip <%= filters.country === country.code ? 'filter-chip-active' : '' %>"
          href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, country: country.code, sort: filters.sort, tag: filters.tag }) %>"
        ><%= country.label %></a>
      <% }) %>
    </div>
  </div>

  <div class="filter-group">
    <p class="filter-group-label">並び順</p>
    <div class="filter-chip-list">
      <a
        class="filter-chip <%= filters.sort !== 'new' ? 'filter-chip-active' : '' %>"
        href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, country: filters.country, sort: 'popular', tag: filters.tag }) %>"
      >人気順</a>
      <a
        class="filter-chip <%= filters.sort === 'new' ? 'filter-chip-active' : '' %>"
        href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, country: filters.country, sort: 'new', tag: filters.tag }) %>"
      >新着順</a>
    </div>
  </div>

  <div class="tag-filter-list">
    <span class="tag-filter-label">タグ:</span>
    <a class="tag <%= !filters.tag ? 'tag-active' : '' %>" href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, country: filters.country, sort: filters.sort }) %>">すべて</a>
    <% tags.forEach((tag) => { %>
      <a class="tag <%= filters.tag === tag ? 'tag-active' : '' %>" href="<%= resolvedActionPath %>?<%= toQuery({ q: filters.q, category: filters.category, country: filters.country, sort: filters.sort, tag }) %>"><%= tag %></a>
    <% }) %>
  </div>

  <% if (shouldShowActiveFilters && hasActiveFilters) { %>
    <p class="active-filters">
      適用中:
      <%= filters.q ? `キーワード: 「${filters.q}」` : '' %>
      <%= filters.q && (filters.category || filters.country || filters.tag || filters.sort === 'new') ? ' / ' : '' %>
      <%= filters.category ? `カテゴリ: ${filters.category}` : '' %>
      <%= filters.category && (filters.country || filters.tag || filters.sort === 'new') ? ' / ' : '' %>
      <%= filters.country ? `国: ${filters.countryLabel || filters.country}` : '' %>
      <%= filters.country && (filters.tag || filters.sort === 'new') ? ' / ' : '' %>
      <%= filters.tag ? `タグ: ${filters.tag}` : '' %>
      <%= filters.tag && filters.sort === 'new' ? ' / ' : '' %>
      <%= filters.sort === 'new' ? '並び順: 新着順' : '' %>
      <a class="button quiet filter-clear-link" href="<%= clearLinkPath %>">解除</a>
    </p>
  <% } %>
</article>
