    </main>
    <footer class="site-footer">
      <div class="container">
        <nav class="footer-links" aria-label="フッターナビゲーション">
          <a href="/affiliate-disclosure">アフィリエイト開示</a>
          <a href="/privacy-policy">プライバシーポリシー</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
        <small>&copy; <%= new Date().getFullYear() %> Influence Book</small>
      </div>
    </footer>
    <script>
      (() => {
        const menu = document.getElementById('mobile-menu-panel');
        const toggleButton = document.querySelector('.mobile-menu-toggle');

        if (!menu || !toggleButton) {
          return;
        }

        const closeButton = menu.querySelector('.mobile-menu-close');
        const backdropButton = menu.querySelector('.mobile-menu-backdrop');
        const menuLinks = menu.querySelectorAll('.mobile-menu-nav a');
        let closeTimer = null;

        const openMenu = () => {
          if (!menu.hidden && !menu.classList.contains('is-closing')) {
            return;
          }

          if (closeTimer) {
            clearTimeout(closeTimer);
            closeTimer = null;
          }
          menu.hidden = false;
          menu.classList.remove('is-closing');
          requestAnimationFrame(() => menu.classList.add('is-open'));
          toggleButton.setAttribute('aria-expanded', 'true');
          document.body.classList.add('mobile-menu-open');
          closeButton?.focus();
        };

        const closeMenu = ({ restoreFocus = true } = {}) => {
          if (menu.hidden || menu.classList.contains('is-closing')) {
            return;
          }

          menu.classList.remove('is-open');
          menu.classList.add('is-closing');
          toggleButton.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('mobile-menu-open');

          closeTimer = window.setTimeout(() => {
            menu.hidden = true;
            menu.classList.remove('is-closing');
            closeTimer = null;
          }, 280);

          if (restoreFocus) {
            toggleButton.focus();
          }
        };

        toggleButton.addEventListener('click', () => {
          if (menu.hidden) {
            openMenu();
            return;
          }

          closeMenu();
        });

        closeButton?.addEventListener('click', closeMenu);
        backdropButton?.addEventListener('click', closeMenu);
        menuLinks.forEach((link) => {
          link.addEventListener('click', () => closeMenu({ restoreFocus: false }));
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !menu.hidden) {
            closeMenu();
          }
        });
      })();
    </script>
  </body>
</html>
