<%- include('partials/header') %>

<section class="card person-header-card page-section detail-hero">
  <div class="book-card">
    <% if (book.coverUrl) { %>
      <img src="<%= book.coverUrl %>" alt="<%= book.title %> の書影" class="book-cover book-cover-lg" />
    <% } else { %>
      <div class="book-cover book-cover-lg book-cover-placeholder" aria-hidden="true"><span>No Cover</span></div>
    <% } %>

    <div>
      <h1><%= book.title %></h1>
      <p class="book-author"><strong>著者:</strong> <%= book.author || '未設定' %></p>
      <p><%= book.description || '説明はまだ登録されていません。' %></p>
      <div class="links purchase-links">
        <% if (book.amazonUrl) { %>
          <a class="button-link" href="<%= book.amazonUrl %>" target="_blank" rel="noopener noreferrer">Amazonで見る</a>
        <% } %>
        <% if (book.rakutenUrl) { %>
          <a class="button-link" href="<%= book.rakutenUrl %>" target="_blank" rel="noopener noreferrer">楽天で見る</a>
        <% } %>
      </div>
    </div>
  </div>
</section>

<section class="page-section section-separator">
  <header class="section-head">
    <h2>この本に影響を受けた人物</h2>
  </header>

  <div class="grid">
    <% if (influencedPeople.length === 0) { %>
      <p class="empty-state">この本に紐づく人物はまだ登録されていません。</p>
    <% } %>

    <% influencedPeople.forEach((person) => { %>
      <%- include('partials/person-card', { person, headingLevel: 'h3', showMeta: false, linkLabel: '人物詳細へ' }) %>
    <% }) %>
  </div>
</section>

<section class="page-section section-separator">
  <header class="section-head">
    <h2>関連人物</h2>
    <p class="section-description">タグ・カテゴリ・関連情報をもとに表示しています。</p>
  </header>

  <div class="grid">
    <% if (relatedPeople.length === 0) { %>
      <p class="empty-state">関連人物はまだ見つかりません。</p>
    <% } %>

    <% relatedPeople.forEach((person) => { %>
      <%- include('partials/person-card', { person, headingLevel: 'h3', showMeta: true, linkLabel: '人物詳細へ' }) %>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
