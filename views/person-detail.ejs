<%- include('partials/header') %>

<section class="card person-header-card page-section detail-hero">
  <% const displayName = person.displayNameJa || person.name; %>
  <div class="person-detail-header">
    <% if (person.imageUrl) { %>
      <img src="<%= person.imageUrl %>" alt="<%= displayName %> の写真" class="person-detail-image" />
    <% } else { %>
      <div class="person-detail-image person-detail-image-placeholder" aria-hidden="true">
        <span><%= displayName.slice(0, 1).toUpperCase() %></span>
      </div>
    <% } %>
    <div class="person-detail-headings">
      <h1><%= displayName %></h1>
      <p class="section-description"><%= person.occupation || '肩書き未設定' %></p>
    </div>
  </div>
  <p class="person-category">カテゴリ: <%= person.category || '未設定' %></p>

  <% if (person.coreMessage) { %>
    <p class="person-core-message">"<%= person.coreMessage %>"</p>
  <% } %>

  <% if (person.tags && person.tags.length > 0) { %>
    <div class="keywords person-tags">
      <% person.tags.forEach((tag) => { %>
        <span class="tag"><%= tag %></span>
      <% }) %>
    </div>
  <% } %>

  <div class="person-detail-meta">
    <div class="card-subsection detail-block thought-traits-block">
      <h2>思考の特徴</h2>
      <p class="section-description">意思決定の軸として繰り返し現れる、思考の柱を整理しています。</p>
      <% if (person.thoughtTraits && person.thoughtTraits.length > 0) { %>
        <ul class="thought-traits-list">
          <% person.thoughtTraits.forEach((trait) => { %>
            <li><%= trait %></li>
          <% }) %>
        </ul>
      <% } else { %>
        <p class="text-muted">思考の特徴はまだ登録されていません。</p>
      <% } %>
    </div>

    <div class="card-subsection detail-block text-block summary-block">
      <h2>思考と意思決定の要約</h2>
      <p class="section-description">この人物が何を優先し、どのように判断するかを先に把握できます。</p>
      <p class="person-longtext"><%= person.summary || '思考の要約はまだ登録されていません。' %></p>
    </div>

    <div class="card-subsection detail-block text-block career-block">
      <h2>経歴（タイムライン）</h2>
      <p class="section-description">主要な転機を時系列で確認できます。</p>
      <% const careerLines = person.career ? person.career.split('\n').map((line) => line.trim()).filter(Boolean) : []; %>
      <% const shouldShowTimeline = careerLines.length > 1; %>
      <% if (shouldShowTimeline) { %>
        <ul class="career-timeline">
          <% careerLines.forEach((line) => { %>
            <li><span><%= line %></span></li>
          <% }) %>
        </ul>
      <% } else if (careerLines.length === 1) { %>
        <p class="person-longtext"><%= careerLines[0] %></p>
      <% } else { %>
        <p class="person-longtext">経歴はまだ登録されていません。</p>
      <% } %>
    </div>

    <div class="card-subsection detail-block text-block">
      <h2>人物理解の補足</h2>
      <p class="section-description">経歴だけでは見えない背景や人物像を補うセクションです。</p>
      <p class="person-longtext"><%= person.bio || '紹介文はまだ登録されていません。' %></p>
    </div>

    <div class="card-subsection detail-block">
      <h2>キーワード</h2>
      <% if (person.keywords && person.keywords.length > 0) { %>
        <div class="keywords">
          <% person.keywords.forEach((keyword) => { %>
            <span class="tag"><%= keyword %></span>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-muted">キーワードはまだ登録されていません。</p>
      <% } %>
    </div>
  </div>
</section>

<section class="page-section influence-section section-separator">
  <header class="section-head">
    <h2>影響を受けた本</h2>
    <p class="section-description">単なる書籍要約ではなく、<%= displayName %> のどの思考軸につながるかが分かるように整理しています。</p>
  </header>
  <div class="stack">
    <% if (influenceBooks.length === 0) { %>
      <article class="card empty-state">
        <p>まだ本が登録されていません。</p>
      </article>
    <% } %>

    <% influenceBooks.forEach((influence) => { %>
      <% const book = influence.bookId; %>
      <article class="card book-card influence-card">
        <% if (book && book.coverUrl) { %>
          <img src="<%= book.coverUrl %>" alt="<%= book.title %> の書影" class="book-cover" />
        <% } else { %>
          <div class="book-cover book-cover-placeholder" aria-hidden="true">
            <span>No Cover</span>
          </div>
        <% } %>

        <div class="book-card-content">
          <header class="book-meta book-meta-with-label">
            <div class="book-section-label">Influence</div>
            <% if (influence.featuredOrder !== undefined && influence.featuredOrder !== null) { %>
              <div class="featured-order">重要度 <%= influence.featuredOrder %></div>
            <% } %>
            <h3><%= book ? book.title : '本情報なし' %></h3>
            <p class="book-author"><strong>著者:</strong> <%= book && book.author ? book.author : '未設定' %></p>
            <% if (book && book.slug) { %>
              <a class="person-link" href="/books/<%= book.slug %>">本の詳細を見る</a>
            <% } %>
          </header>

          <div class="card-subsection detail-block">
            <h4><%= displayName %>との接点・重要性</h4>
            <p class="person-longtext"><%= influence.impactSummary || '未設定' %></p>
          </div>

          <div class="card-subsection detail-block source-block">
            <h4>出典</h4>
            <p class="source-title"><%= influence.sourceTitle || '未設定' %></p>
            <% if (influence.sourceUrl) { %>
              <a class="source-link" href="<%= influence.sourceUrl %>" target="_blank" rel="noopener noreferrer">出典を見る</a>
            <% } %>
          </div>

          <div class="links purchase-links">
            <% if (book && book.amazonUrl) { %>
              <a class="button-link" href="<%= book.amazonUrl %>" target="_blank" rel="noopener noreferrer">Amazonで見る</a>
            <% } %>
            <% if (book && book.rakutenUrl) { %>
              <a class="button-link" href="<%= book.rakutenUrl %>" target="_blank" rel="noopener noreferrer">楽天で見る</a>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="page-section influence-section section-separator">
  <header class="section-head">
    <h2>この人を知る本</h2>
    <p class="section-description">影響源の本とは別に、<%= displayName %> という人物そのものを理解するための書籍をまとめています。</p>
  </header>
  <div class="stack">
    <% if (aboutBooks.length === 0) { %>
      <article class="card empty-state">
        <p>まだ本が登録されていません。</p>
      </article>
    <% } %>

    <% aboutBooks.forEach((influence) => { %>
      <% const book = influence.bookId; %>
      <article class="card book-card influence-card">
        <% if (book && book.coverUrl) { %>
          <img src="<%= book.coverUrl %>" alt="<%= book.title %> の書影" class="book-cover" />
        <% } else { %>
          <div class="book-cover book-cover-placeholder" aria-hidden="true">
            <span>No Cover</span>
          </div>
        <% } %>

        <div class="book-card-content">
          <header class="book-meta book-meta-with-label">
            <div class="book-section-label book-section-label-about">About</div>
            <h3><%= book ? book.title : '本情報なし' %></h3>
            <p class="book-author"><strong>著者:</strong> <%= book && book.author ? book.author : '未設定' %></p>
            <% if (book && book.slug) { %>
              <a class="person-link" href="/books/<%= book.slug %>">本の詳細を見る</a>
            <% } %>
          </header>

          <div class="card-subsection detail-block">
            <h4>人物理解のポイント</h4>
            <p class="person-longtext"><%= influence.impactSummary || '未設定' %></p>
          </div>

          <div class="card-subsection detail-block source-block">
            <h4>出典</h4>
            <p class="source-title"><%= influence.sourceTitle || '未設定' %></p>
            <% if (influence.sourceUrl) { %>
              <a class="source-link" href="<%= influence.sourceUrl %>" target="_blank" rel="noopener noreferrer">出典を見る</a>
            <% } %>
          </div>

          <div class="links purchase-links">
            <% if (book && book.amazonUrl) { %>
              <a class="button-link" href="<%= book.amazonUrl %>" target="_blank" rel="noopener noreferrer">Amazonで見る</a>
            <% } %>
            <% if (book && book.rakutenUrl) { %>
              <a class="button-link" href="<%= book.rakutenUrl %>" target="_blank" rel="noopener noreferrer">楽天で見る</a>
            <% } %>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>

<section class="page-section section-separator">
  <header class="section-head">
    <h2>次に読む人物</h2>
    <p class="section-description">思考軸やテーマが近い人物です。続けて読むと比較しながら理解を深められます。</p>
  </header>

  <% if (relatedPeople.length === 0) { %>
    <article class="card empty-state">
      <p>関連人物はまだ見つかりません。</p>
    </article>
  <% } else { %>
    <div class="grid related-people-grid">
      <% relatedPeople.forEach((relatedPerson) => { %>
        <% const relatedDisplayName = relatedPerson.displayNameJa || relatedPerson.name; %>
        <article class="card person-card">
          <div class="person-visual-wrap">
            <% if (relatedPerson.imageUrl) { %>
              <img src="<%= relatedPerson.imageUrl %>" alt="<%= relatedDisplayName %> の写真" class="person-visual" loading="lazy" />
            <% } else { %>
              <div class="person-visual person-visual-placeholder" aria-hidden="true">
                <span><%= relatedDisplayName.slice(0, 1).toUpperCase() %></span>
              </div>
            <% } %>
          </div>
          <h3 class="person-card-title"><%= relatedDisplayName %></h3>
          <p class="person-role"><%= relatedPerson.occupation || '肩書き未設定' %></p>
          <p class="person-intro"><%= relatedPerson.intro || '' %></p>
          <p class="person-category">カテゴリ: <%= relatedPerson.category || '未設定' %></p>
          <a class="person-link" href="/people/<%= relatedPerson.slug %>">詳細を見る</a>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
